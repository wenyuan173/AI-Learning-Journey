   "source": [
    "import pandas as pd\n",
    "\n",
    "s1=pd.Series([\"A\",\"B\"],index=[1,2])\n",
    "s2=pd.Series([\"C\",\"D\"],index=[3,4])\n",
    "s3=pd.Series([\"E\",\"F\"],index=[5,6])\n",
    "\n",
    "#默认按行拼接（竖着列下去）\n",
    "pd.concat([s1,s2,s3])"
   ],
