   "source": [
    "# 处理series和dataframe\n",
    "import pandas as pd\n",
    "\n",
    "def func(item):\n",
    "    return item * 20\n",
    "\n",
    "s1 = pd.Series([1,2,3])\n",
    "result = s1.apply(func)\n",
    "print(result)"
   ],
